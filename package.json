{
  "name": "@gesslar/starlight-class-browser",
  "version": "1.0.1",
  "description": "A class browser for starlight/astro-based things.",
  "keywords": [
    "astro",
    "starlight",
    "component",
    "class",
    "browser"
  ],
  "homepage": "https://starlight-class-browser.gesslar.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/gesslar-class-browser.git"
  },
  "license": "0BSD",
  "author": "gesslar",
  "type": "module",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./components/*": "./components/*",
    "./src/*": "./src/*"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "files": [
    "index.js",
    "components/",
    "src/",
    "types/"
  ],
  "scripts": {
    "types:build": "tsc -p tsconfig.types.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "test": "vitest run",
    "docs:dev": "npm run dev --prefix docs",
    "docs:start": "npm run start --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "docs:preview": "npm run preview --prefix docs"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.38.2",
    "@gesslar/uglier": "^2.4.0",
    "astro": "^6.1.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
