---
import TargetLink from "./TargetLink.astro";

const { type, highlight = "type", hint, target } = Astro.props;
const hasDesc = Astro.slots.has("default");
const hasFooter = hint || target;
---

<div class={`cb-returns ${hasFooter ? "cb-returns-hinted" : ""}`}>
  <div class="cb-returns-row">
    <span class="cb-returns-label">returns</span>
    <span class={`cb-hl cb-returns-type-name cb-hl-${highlight}`}>{type}</span>
    {hasDesc && <span class="cb-returns-desc"><slot /></span>}
  </div>
  {hasFooter && (
    <div class="cb-hint-row">
      {hint && <small class="cb-hint">{hint}</small>}
      {target && <TargetLink target={target} />}
    </div>
  )}
</div>
