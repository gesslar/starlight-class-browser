---
const { name, visibility, highlight = "function", open = false } = Astro.props;

const modifiers = visibility ? visibility.trim().split(/\s+/) : [];
const primaryVis = modifiers[0] || "";
const visClass = primaryVis ? `cb-vis-${primaryVis}` : "";
---

<details class={`cb-method ${visClass}`} id={name} open={open}>
  <summary>
    <a class="cb-anchor" href={`#${name}`} aria-label={`Link to ${name}`}>#</a>
    {modifiers.map((mod) => (
      <span class={`cb-badge cb-badge-${mod}`}>{mod}</span>
    ))}
    <span class={`cb-hl cb-hl-${highlight}`}>{name}</span>
  </summary>
  <div class="cb-method-body">
    <slot />
  </div>
</details>
