---
import TargetLink from "./TargetLink.astro";

const { name, type, highlight = "parameter", typeHighlight, hint, target } = Astro.props;
const hasDesc = Astro.slots.has("default");
const hasFooter = hint || target;
---

<div class={`cb-param ${hasFooter ? "cb-param-hinted" : ""}`}>
  <div class="cb-param-row">
    <span class="cb-param-label">param</span>
    <span class={`cb-hl cb-param-name cb-hl-${highlight}`}>{name}</span>
    {type && <span class={`cb-type-annotation ${typeHighlight ? `cb-hl cb-hl-${typeHighlight}` : ""}`}>{type}</span>}
    {hasDesc && <span class="cb-param-desc"><slot /></span>}
  </div>
  {hasFooter && (
    <div class="cb-hint-row">
      {hint && <small class="cb-hint">{hint}</small>}
      {target && <TargetLink target={target} />}
    </div>
  )}
</div>
