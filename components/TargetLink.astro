---
const { target } = Astro.props;

const isExternal = /^https?:\/\//.test(target);
const href = isExternal ? target : target;
const extraAttrs = isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a class="cb-target" href={href} title={target} {...extraAttrs}>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
</a>
